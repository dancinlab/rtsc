&control
  calculation='scf'
  prefix='ni3in'
  outdir='./out'
  pseudo_dir='./pseudo'
  tprnfor=.true.
  tstress=.true.
  verbosity='high'
/
&system
  ibrav=4
  celldm(1)=9.9892
  celldm(3)=0.80268
  nat=8
  ntyp=2
  ecutwfc=60
  ecutrho=480
  occupations='smearing'
  smearing='mp'
  degauss=0.025
  nspin=2
  starting_magnetization(1)=0.2
  starting_magnetization(2)=0.0
/
&electrons
  conv_thr=1.0d-8
  mixing_beta=0.1
  mixing_mode='local-TF'
  electron_maxstep=300
/
ATOMIC_SPECIES
  Ni 58.693 Ni.pbe-spn-kjpaw_psl.1.0.0.UPF
  In 114.818 In.pbe-dn-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Ni 0.500000 0.000000 0.250000
  Ni 0.000000 0.500000 0.250000
  Ni 0.500000 0.500000 0.250000
  Ni 0.500000 0.000000 0.750000
  Ni 0.000000 0.500000 0.750000
  Ni 0.500000 0.500000 0.750000
  In 0.333333 0.666667 0.250000
  In 0.666667 0.333333 0.750000
K_POINTS automatic
  8 8 8 0 0 0
