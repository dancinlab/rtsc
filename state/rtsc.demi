  "R8 4/4 CLOSURE @ G33; R4 vindicated (06cfad0 · 0 RTSC predicted / 7 candidates).",
  "measurement_gate = GATE_OPEN permanently — design scaffolding is not an absorption claim (g3).",
]

# --- WIRED (ROI 10 · pyfemm cohort pickup · macOS hard-block): analyze ------
# Existing producer: stdlib/rtsc/pyfemm_magnetics.py. FEMM Windows-only,
# Wine-only on macOS — Linux pool honest-skip on Darwin.
[cell.analyze]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/rtsc/analyze.py
record_kind       = rtsc_analyze_record
output_dir        = exports/rtsc/analyze
required_deps     = python3, pyfemm
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "pyfemm 2-D HTS magnetics — placeholder HTS-tape proxy; macOS honest-skip (FEMM Windows binary, Wine-only).",
  "kernels/em_2d/ promotion candidate at 2nd consumer per D72.",
  "absorbed=true requires accredited 4-probe transport + Meissner expulsion measurements (g3).",
]

