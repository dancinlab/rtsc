# rtsc.demi — verb-cell manifest for the rtsc (room-temperature superconductor
# discovery · honest falsification framework) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/rtsc/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("rtsc", verb)
#
# Format: cellrun.hexa Phase A dialect.
#
# Citations (anchored, not repeated per-cell — see RTSC.md):
#   - pyfemm (FEMM Windows · Wine-only on macOS · macOS hard-block) —
#     rtsc+analyze 2-D HTS magnetics (ROI 10 · cohort pickup)
#   - GetDP (open · GPL-3) — rtsc+verify HTS H-/A-phi 3-D EM (ROI 16)
#   - BETE-NET (open ML model) — RTSC.md §9.2 7-candidate calibration
#     (16.6% best · 1-atom OOD 454-1424%)
#   - Materials Project · OPTIMADE · AFLOW · JARVIS — DFT corpus
#   - HTS Modelling Workgroup · Hauser arxiv:0811.2883
#
# Domain caveat (applies to every cell):
# rtsc is FALSIFIER-FIRST (R8 4/4 CLOSURE at G33). ALL cells stay
# GATE_OPEN / absorbed=false (g3): RTSC.md's central claim is that
# novel-discovery requires falsifier cascade passage + accredited
# 4-probe transport + Meissner expulsion + measured H_c2 · T_c — none
# of which this map flips. R4 vindicated: 0 RTSC predicted of 7 funnel
# candidates (06cfad0).

# --- WIRED: specify (RTSC candidate-class spec skeleton) --------------------
[cell.specify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/rtsc/specify.py
record_kind       = rtsc_specify_record
output_dir        = exports/rtsc/specify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "RTSC candidate-class spec skeleton (target T_c · pressure regime · phonon-mediated vs unconventional) — TEMPLATE.",
  "LK-99 / hydride-class / copper-oxide reference targets; NO claim that any candidate IS RTSC (R4 axis).",
  "measurement_gate = GATE_OPEN permanently — specify skeleton is not an absorption claim (g3).",
]

