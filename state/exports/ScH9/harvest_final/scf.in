&control
  !   the vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   denser than the relax mesh (16x16x12 hexagonal).
  calculation = 'scf'
  prefix = 'sch9'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 10
  ntyp = 2
  ecutwfc = 80.0
  ecutrho = 640.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic superhydride).
  conv_thr = 1.0d-12
  mixing_beta = 0.3
  mixing_mode = 'plain'
  electron_maxstep = 400
/

ATOMIC_SPECIES
  Sc 44.956 Sc.pbe-spn-rrkjus_psl.1.0.0.UPF
  H  1.008  H.pbe-rrkjus_psl.1.0.0.UPF

