&control
  calculation = 'vc-relax'
  prefix = 'bkboro'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'high'
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-5
  nstep = 200
/
&system
  ! BK-borophene: bilayer AA-stacked kagome boron, hexagonal ibrav=4.
  ! 6 B/cell (2 kagome sublayers x 3 edge-midpoint sites). a~2.95A, vacuum~18A.
  ! refs arXiv:2307.07137 / 2406.18165. light-element line-graph kagome flat band.
  ibrav = 4
  celldm(1) = 5.574692
  celldm(3) = 6.779661
  nat = 6
  ntyp = 1
  ecutwfc = 50
  ecutrho = 400
  assume_isolated = '2D'
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  mixing_mode = 'local-TF'
  electron_maxstep = 400
  diagonalization = 'david'
/
&ions
  ion_dynamics = 'bfgs'
/
&cell
  cell_dynamics = 'bfgs'
  press = 0.0
  press_conv_thr = 0.1
  cell_dofree = '2Dxy'
/
ATOMIC_SPECIES
  B 10.811 B.pbe-n-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  B 0.500000 0.000000 0.450000
  B 0.000000 0.500000 0.450000
  B 0.500000 0.500000 0.450000
  B 0.500000 0.000000 0.550000
  B 0.000000 0.500000 0.550000
  B 0.500000 0.500000 0.550000
K_POINTS automatic
  12 12 1 0 0 0
