&CONTROL
  calculation     = 'scf'
  prefix          = 'libeb'
  outdir          = './out'
  pseudo_dir      = './pseudo'
  tstress         = .true.
  tprnfor         = .true.
  verbosity       = 'high'
/
&SYSTEM
  ibrav           = 0
  nat             = 6
  ntyp            = 3
  ecutwfc         = 60
  ecutrho         = 480
  nosym           = .false.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-12
  mixing_beta     = 0.3
  diagonalization = 'david'
  electron_maxstep = 400
/
