&CONTROL
  calculation     = 'scf'
  prefix          = 'cah6'
  outdir          = './out'
  verbosity       = 'high'
  pseudo_dir      = './pseudo'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav = 0
  nat             = 7
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 320
  nosym           = .true.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
