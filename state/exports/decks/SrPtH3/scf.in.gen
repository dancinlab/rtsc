&control
  !   vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   16x16x16 here (denser than the 12^3 relax mesh).
  calculation = 'scf'
  prefix = 'srpth3'
  outdir = '/home/aiden/rtsc_srpth3/out'
  pseudo_dir = '/home/aiden/rtsc_srpth3/pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic perovskite).
  conv_thr = 1.0d-12
  mixing_beta = 0.4
  electron_maxstep = 400
/

ATOMIC_SPECIES
  Sr 87.62   Sr.pbe-spn-rrkjus_psl.1.0.0.UPF
  Pt 195.084 Pt.pbe-n-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF

CELL_PARAMETERS (angstrom)
  3.79354   -1.14842e-08   1.53123e-08
  -1.14842e-08   3.79354   0.0
  1.53123e-08   0.0   3.79354
ATOMIC_POSITIONS (crystal)
Sr            0.5000000049        0.4999999947        0.4999999978
Pt           -0.0000000179        0.0000000152        0.0000000073
H             0.5000000043       -0.0000000035       -0.0000000016
H             0.0000000045        0.4999999971       -0.0000000014
H             0.0000000043       -0.0000000035        0.4999999979
K_POINTS automatic
  16 16 16 0 0 0


