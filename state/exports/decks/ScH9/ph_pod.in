ScH9 phonon + electron-phonon 2x2x2 q (fresh, pod re-fire)
&inputph
  prefix = 'sch9'
  outdir = './out'
  fildyn = 'sch9.dyn'
  fildvscf = 'sch9.dvscf'
  ldisp = .true.
  nq1 = 2, nq2 = 2, nq3 = 2
  tr2_ph = 1.0d-14
  recover = .true.
  electron_phonon = 'simple'
  el_ph_sigma = 0.005
  el_ph_nsigma = 10
  alpha_mix(1) = 0.3
  max_seconds = 86400
/
