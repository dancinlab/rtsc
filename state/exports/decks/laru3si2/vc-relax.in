&control
  calculation = 'vc-relax'
  prefix = 'laru3si2'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-5
  nstep = 200
/
&system
  ! LaRu3Si2 CeCo3B2-type, hexagonal P6/mmm (No.191). nat=6, ntyp=3.
  !   La 1a (0,0,0)             -- triangular net
  !   Ru 3g (1/2,0,1/2) + sym   -- KAGOME net at z=1/2 (the flat-band layer)
  !   Si 2c (1/3,2/3,0) + sym   -- honeycomb net at z=0
  ! Wyckoff 1a/3g/2c have NO free internal params -> vc-relax only adjusts cell (a, c/a).
  ! STARTING POINT = experimental lattice (Vandenberg-Barz CeCo3B2-type / kagome-SC literature):
  !   a ~= 5.68 Ang = 10.733 Bohr, c ~= 3.57 Ang -> c/a ~= 0.6285. RELAX to DFT equilibrium.
  ibrav = 4
  celldm(1) = 10.7335
  celldm(3) = 0.62852
  nat = 6
  ntyp = 3
  ecutwfc = 90
  ecutrho = 360
  nspin = 2
  starting_magnetization(1) = 0.0
  starting_magnetization(2) = 0.1
  starting_magnetization(3) = 0.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.4
  electron_maxstep = 400
/
&ions
  ion_dynamics = 'bfgs'
/
&cell
  cell_dynamics = 'bfgs'
  press_conv_thr = 0.5
/
ATOMIC_SPECIES
  La 138.905  La_ONCV_PBE_sr.upf
  Ru 101.07   Ru_ONCV_PBE_sr.upf
  Si 28.0855  Si_ONCV_PBE_sr.upf
ATOMIC_POSITIONS crystal
  La 0.000000 0.000000 0.000000
  Ru 0.500000 0.000000 0.500000
  Ru 0.000000 0.500000 0.500000
  Ru 0.500000 0.500000 0.500000
  Si 0.333333 0.666667 0.000000
  Si 0.666667 0.333333 0.000000
K_POINTS automatic
  12 12 12 0 0 0
