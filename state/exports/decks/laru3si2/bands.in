&control
  calculation = 'bands'
  prefix = 'laru3si2'
  outdir = './out'
  pseudo_dir = './pseudo'
/
&system
  ! flat-band measurement path: Gamma-K-M-Gamma-A-L-H (hexagonal). Ru-kagome flat band is flat
  ! across the Gamma-K-M plane near E_F (literature: Ru-dz2 FB ~0.1 eV ABOVE E_F). Report dE = E_flat - E_F.
  ! celldm SET FROM vc-relax OUTPUT (RELAXED: a=5.7175 Ang, c=3.5732 Ang). Same as scf.in.
  ! NOTE (gate-check run): default-david stalled on empty metallic bands -> use diago_full_acc=.false.
  !   + conv 1e-6 + nbnd=60 (see bands_fix.in in harvest); flat-band positions converge < gate resolution.
  ibrav = 4
  celldm(1) = 10.80445
  celldm(3) = 0.62496
  nat = 6
  ntyp = 3
  ecutwfc = 90
  ecutrho = 360
  nspin = 2
  starting_magnetization(1) = 0.0
  starting_magnetization(2) = 0.1
  starting_magnetization(3) = 0.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
  nbnd = 80
/
&electrons
  conv_thr = 1.0d-9
/
ATOMIC_SPECIES
  La 138.905  La_ONCV_PBE_sr.upf
  Ru 101.07   Ru_ONCV_PBE_sr.upf
  Si 28.0855  Si_ONCV_PBE_sr.upf
ATOMIC_POSITIONS crystal
  La 0.000000 0.000000 0.000000
  Ru 0.500000 0.000000 0.500000
  Ru 0.000000 0.500000 0.500000
  Ru 0.500000 0.500000 0.500000
  Si 0.333333 0.666667 0.000000
  Si 0.666667 0.333333 0.000000
K_POINTS crystal_b
  7
  0.00000 0.00000 0.00000 40   ! Gamma
  0.33333 0.33333 0.00000 40   ! K
  0.50000 0.00000 0.00000 40   ! M
  0.00000 0.00000 0.00000 40   ! Gamma
  0.00000 0.00000 0.50000 40   ! A
  0.50000 0.00000 0.50000 40   ! L
  0.33333 0.33333 0.50000 1    ! H
