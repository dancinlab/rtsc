&control
  !   vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   16x16x16 here (denser than the 12^3 relax mesh).
  calculation = 'scf'
  prefix = 'yauh3'
  outdir = '/home/aiden/rtsc_yauh3/out'
  pseudo_dir = '/home/aiden/rtsc_yauh3/pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic perovskite).
  conv_thr = 1.0d-12
  mixing_beta = 0.3
  electron_maxstep = 400
/

ATOMIC_SPECIES
  Y  88.906  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  Au 196.967 Au.pbe-n-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF

CELL_PARAMETERS (angstrom)
  3.76402   -5.75906e-08   4.67923e-08
  -5.75906e-08   3.76402   5.75906e-08
  4.67923e-08   5.75906e-08   3.76402
ATOMIC_POSITIONS (crystal)
Y             0.4999999980        0.5000000006        0.4999999999
Au            0.0000000243        0.0000000008       -0.0000000049
H             0.4999999981       -0.0000000002        0.0000000026
H            -0.0000000100        0.4999999990        0.0000000025
H            -0.0000000104       -0.0000000002        0.4999999999
K_POINTS automatic
  16 16 16 0 0 0


