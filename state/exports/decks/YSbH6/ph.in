YSbH6 phonon + electron-phonon 4x4x4 q (A15 ternary hydride - Cr3Si motif)
&inputph
  prefix = 'ysbh6'
  outdir = './out'
  fildyn = 'ysbh6.dyn'
  fildvscf = 'ysbh6.dvscf'
  ldisp = .true.
  nq1 = 4, nq2 = 4, nq3 = 4
  tr2_ph = 1.0d-14
  recover = .true.
  electron_phonon = 'simple'
  el_ph_sigma = 0.005
  el_ph_nsigma = 10
/
