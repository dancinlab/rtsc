&control
  calculation = 'scf'
  prefix = 'ysbh6'
  outdir = './out'
  pseudo_dir = './pseudo'
  verbosity = 'high'
  tstress = .true.
  tprnfor = .true.
/
&system
  ibrav = 0
  nat = 8
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  nosym = .true.
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-12
  mixing_beta = 0.4
  electron_maxstep = 400
/
