&control
  calculation = 'scf'
  prefix = 'ceh9'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-5
  nstep = 200
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 20
  ntyp = 2
  ecutwfc = 70.0
  ecutrho = 560.0
  nosym = .true.
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-12
  mixing_beta = 0.4
  electron_maxstep = 400
/

