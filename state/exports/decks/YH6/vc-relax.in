&CONTROL
  calculation     = 'vc-relax'
  prefix          = 'yh6'
  outdir          = './out'
  pseudo_dir      = './pseudo'
  forc_conv_thr   = 1.0d-4
  etot_conv_thr   = 1.0d-6
  tstress         = .true.
  tprnfor         = .true.
  nstep           = 200
/
&SYSTEM
  ibrav           = 3                ! BCC primitive, Im-3m (SG 229) - YH6 sodalite (Troyan 2021, 224K@166GPa)
  celldm(1)       = 6.7100           ! a ~3.55 A @ 166 GPa (vc-relax refines)
  nat             = 7                ! 1 Y (2a) + 6 H (12d) per BCC-primitive
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
&IONS
  ion_dynamics    = 'bfgs'
/
&CELL
  cell_dynamics   = 'bfgs'
  press           = 1660.0           ! target 166 GPa  (QE press unit = kbar; 166 GPa = 1660 kbar)
  press_conv_thr  = 0.5
  cell_dofree     = 'all'
/
! FALLBACK: if dynamic instability persists, re-run with press = 2000.0 (200 GPa).
ATOMIC_SPECIES
  Y   88.9059  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  H    1.008   H.pbe-rrkjus_psl.1.0.0.UPF

! YH6 sodalite: Y @ 2a (0,0,0), H @ 12d (1/4,1/2,0) and symmetry-equivalents (H24 cage).
! BCC-primitive representation; vc-relax refines.
ATOMIC_POSITIONS crystal
  Y    0.0000000   0.0000000   0.0000000
  H    0.2500000   0.5000000   0.0000000
  H    0.5000000   0.0000000   0.2500000
  H    0.0000000   0.2500000   0.5000000
  H    0.7500000   0.5000000   0.0000000
  H    0.5000000   0.0000000   0.7500000
  H    0.0000000   0.7500000   0.5000000

K_POINTS automatic
  16 16 16  0 0 0
