&CONTROL
  calculation     = 'scf'
  prefix          = 'yh6'
  outdir          = './out'
  verbosity       = 'high'
  pseudo_dir      = './pseudo'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav           = 3                ! BCC primitive, Im-3m (SG 229) - YH6 sodalite (Troyan 2021, 224K@166GPa)
  celldm(1)       = 6.7100           ! REPLACE with relaxed celldm(1) from vc-relax.out
  nat             = 7                ! 1 Y (2a) + 6 H (12d) per BCC-primitive
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Y   88.9059  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  H    1.008   H.pbe-rrkjus_psl.1.0.0.UPF

! YH6 sodalite: Y @ 2a (0,0,0), H @ 12d (1/4,1/2,0) and symmetry-equivalents (H24 cage).
! BCC-primitive representation; vc-relax refines.
ATOMIC_POSITIONS crystal
  Y    0.0000000   0.0000000   0.0000000
  H    0.2500000   0.5000000   0.0000000
  H    0.5000000   0.0000000   0.2500000
  H    0.0000000   0.2500000   0.5000000
  H    0.7500000   0.5000000   0.0000000
  H    0.5000000   0.0000000   0.7500000
  H    0.0000000   0.7500000   0.5000000

K_POINTS automatic
  16 16 16  0 0 0
