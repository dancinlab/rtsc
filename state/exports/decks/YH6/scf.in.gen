&CONTROL
  calculation     = 'scf'
  prefix          = 'yh6'
  outdir          = './out'
  verbosity       = 'high'
  pseudo_dir      = './pseudo'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav = 0
  nat             = 7                ! 1 Y (2a) + 6 H (12d) per BCC-primitive
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Y   88.9059  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  H    1.008   H.pbe-rrkjus_psl.1.0.0.UPF

! YH6 sodalite: Y @ 2a (0,0,0), H @ 12d (1/4,1/2,0) and symmetry-equivalents (H24 cage).
! BCC-primitive representation; vc-relax refines.

CELL_PARAMETERS (angstrom)
  1.85951   1.6924   1.80674
  -1.71394   1.78341   1.86183
  -1.80677   -1.78909   1.76658
ATOMIC_POSITIONS (crystal)
