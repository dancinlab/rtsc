&control
  calculation = 'scf'
  prefix = 'mosn'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
/
&system
  ! MoSn -- hexagonal P6/mmm (No.191) CoSn-type. Mo kagome net z=0 (Wyckoff 3f), Sn 1a(z=0)+2d(z=1/2).
  ! celldm SET FROM vc-relax OUTPUT (placeholder = starting guess; OVERWRITTEN by relaxed a, c/a).
  ! Gate: confirm kagome FLAT BAND + dE vs E_F; nspin=2 = magnetism DIAGNOSTIC (predicted non-magnetic).
  ibrav = 4
  celldm(1) = 10.59396
  celldm(3) = 0.84778
  nat = 6
  ntyp = 2
  ecutwfc = 90
  ecutrho = 360
  nspin = 2
  starting_magnetization(1) = 0.3
  starting_magnetization(2) = 0.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.4
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Mo 95.95   Mo_ONCV_PBE_sr.upf
  Sn 118.71  Sn_ONCV_PBE_sr.upf
ATOMIC_POSITIONS crystal
  Mo 0.500000 0.000000 0.000000
  Mo 0.000000 0.500000 0.000000
  Mo 0.500000 0.500000 0.000000
  Sn 0.000000 0.000000 0.000000
  Sn 0.333333 0.666667 0.500000
  Sn 0.666667 0.333333 0.500000
K_POINTS automatic
  12 12 12 0 0 0
