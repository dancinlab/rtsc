&control
  calculation = 'vc-relax'
  prefix = 'cosn'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-5
  nstep = 200
/
&system
  ! P6/mmm kagome — Wyckoff 3f/1a/2d have NO free internal params; relaxation only adjusts cell (a, c/a).
  ibrav = 4
  celldm(1) = 9.9760
  celldm(3) = 0.80680
  nat = 6
  ntyp = 2
  ecutwfc = 90
  ecutrho = 360
  nspin = 2
  starting_magnetization(1) = 0.3
  starting_magnetization(2) = 0.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.4
  electron_maxstep = 400
/
&ions
  ion_dynamics = 'bfgs'
/
&cell
  cell_dynamics = 'bfgs'
  press_conv_thr = 0.5
/
ATOMIC_SPECIES
  Co 58.933  Co_ONCV_PBE_sr.upf
  Sn 118.71  Sn_ONCV_PBE_sr.upf
ATOMIC_POSITIONS crystal
  Co 0.500000 0.000000 0.000000
  Co 0.000000 0.500000 0.000000
  Co 0.500000 0.500000 0.000000
  Sn 0.000000 0.000000 0.000000
  Sn 0.333333 0.666667 0.500000
  Sn 0.666667 0.333333 0.500000
K_POINTS automatic
  12 12 12 0 0 0
