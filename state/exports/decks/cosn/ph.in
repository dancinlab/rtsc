CoSn el-ph 2x2x2 q (kagome flat-band RTSC, electron_phonon=simple, nspin=2)
&inputph
  prefix = 'cosn'
  outdir = './out'
  fildyn = './cosn.dyn'
  fildvscf = 'cosn.dvscf'
  ldisp = .true.
  nq1 = 2, nq2 = 2, nq3 = 2
  tr2_ph = 1.0d-14
  recover = .true.
  electron_phonon = 'simple'
  el_ph_sigma = 0.005
  el_ph_nsigma = 10
/
