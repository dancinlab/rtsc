&control
  ! A15 YAuH3 — Y-substituted SrAuH3 perovskite-hydride (RTSC Wave-2, YH10-family).
  ! Anchor: SrAuH3 cubic perovskite Pm-3m (celldm=7.2340 Bohr = 3.828 Ang, d19 reuse).
  ! A-site Sr -> Y to extend the verified YH10 (Tc=227.5K@250GPa, #1909) Y line into
  !   the DISTINCT perovskite-hydride mechanism class (Au-H octahedral framework).
  ! Y (r=1.04 Ang, trivalent) < Sr (1.18 Ang, divalent) -> ~6% A-site contraction +
  !   extra electron count vs Sr; START guess celldm(1)=6.8019 Bohr (=3.599 Ang,
  !   x0.940 SrAuH3). vc-relax FINDS the true a.
  ! Pressure: 50 GPa here (perovskite often stable mid-P, cf. CaAuH3 sister A11).
  !   For an ambient stability test re-run with press=0.0 (1 atm) — see RUNBOOK fallback.
  calculation = 'vc-relax'
  prefix = 'yauh3'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-5
  nstep = 200
  verbosity = 'low'
/
&system
  ! ibrav=1 simple cubic; 5-atom perovskite cell (1 Y + 1 Au + 3 H).
  ! Pm-3m: Y at A-site (1/2,1/2,1/2) corner-equiv, Au at B-site (0,0,0) body-center,
  !   H at the 3 face-centers — Au-H octahedral framework.
  ! nosym=.true. guard: avoids symmetry-detection edge cases during cell relaxation
  !   (high-sym start can mis-assign the point group under stress).
  ibrav = 1
  celldm(1) = 6.8019
  nat = 5
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  nosym = .true.
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic perovskite): tight conv + low mixing + maxiter headroom.
  conv_thr = 1.0d-10
  mixing_beta = 0.3
  electron_maxstep = 400
/
&ions
  ion_dynamics = 'bfgs'
/
&cell
  cell_dynamics = 'bfgs'
  press = 50.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Y  88.906  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  Au 196.967 Au.pbe-n-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Y  0.5 0.5 0.5
  Au 0.0 0.0 0.0
  H  0.5 0.0 0.0
  H  0.0 0.5 0.0
  H  0.0 0.0 0.5
K_POINTS automatic
  12 12 12 0 0 0
