&control
  ! A15 YAuH3 — post-relax SCF. MUST read the relaxed celldm(1) + positions from the
  !   vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  !   The celldm(1) below is the START guess and is overwritten in the RUNBOOK step.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   16x16x16 here (denser than the 12^3 relax mesh).
  calculation = 'scf'
  prefix = 'yauh3'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic perovskite).
  conv_thr = 1.0d-12
  mixing_beta = 0.3
  electron_maxstep = 400
/

ATOMIC_SPECIES
  Y  88.906  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  Au 196.967 Au.pbe-n-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF
  16 16 16 0 0 0

CELL_PARAMETERS bohr
  7.1129621237  0.0000002245  -0.0000000476
  0.0000002245  7.1129620285  -0.0000000068
  -0.0000000476  -0.0000000068  7.1129622598

ATOMIC_POSITIONS crystal
Y             0.5000000008        0.4999999959        0.5000000029
Au            0.0000000177       -0.0000000092        0.0000000005
H             0.5000000007        0.0000000063       -0.0000000028
H            -0.0000000093        0.5000000009       -0.0000000025
H            -0.0000000099        0.0000000061        0.5000000018


