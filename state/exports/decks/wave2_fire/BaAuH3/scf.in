&control
  ! A10 BaAuH3 — post-relax SCF. MUST read the relaxed celldm(1) + positions from the
  !   vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  !   The celldm(1) below is the START guess and is overwritten in the RUNBOOK step.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   16x16x16 here (denser than the 12^3 relax mesh).
  calculation = 'scf'
  prefix = 'baauh3'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic perovskite).
  conv_thr = 1.0d-12
  mixing_beta = 0.4
  electron_maxstep = 400
/

ATOMIC_SPECIES
  Ba 137.327 Ba.pbe-spn-rrkjus_psl.1.0.0.UPF
  Au 196.967 Au.pbe-n-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF
  16 16 16 0 0 0

CELL_PARAMETERS bohr
  7.5797380129  0.0000002013  0.0000002632
  0.0000002013  7.5797383380  -0.0000003638
  0.0000002632  -0.0000003638  7.5797374633

ATOMIC_POSITIONS crystal
Ba            0.5000029891        0.4999994966        0.4999974887
Au           -0.0000007418        0.0000001214        0.0000006512
H             0.4999992264        0.0000001238        0.0000006117
H            -0.0000007368        0.5000001343        0.0000006123
H            -0.0000007370        0.0000001239        0.5000006361


