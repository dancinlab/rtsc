&control
  ! A08 SrPtH3 — post-relax SCF. MUST read the relaxed celldm(1) + positions from the
  !   vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  !   The celldm(1) below is the START guess and is overwritten in the RUNBOOK step.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   16x16x16 here (denser than the 12^3 relax mesh).
  calculation = 'scf'
  prefix = 'srpth3'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 80.0
  ecutrho = 640.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic perovskite).
  conv_thr = 1.0d-12
  mixing_beta = 0.4
  electron_maxstep = 400
/

ATOMIC_SPECIES
  Sr 87.62   Sr.pbe-spn-rrkjus_psl.1.0.0.UPF
  Pt 195.084 Pt.pbe-n-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF
  16 16 16 0 0 0

CELL_PARAMETERS bohr
  7.1687458983  -0.0000000145  0.0000001374
  -0.0000000145  7.1687458260  -0.0000000723
  0.0000001374  -0.0000000723  7.1687462673

ATOMIC_POSITIONS crystal
Sr            0.5000000295        0.4999999406        0.5000000187
Pt           -0.0000000644        0.0000002951       -0.0000000606
H             0.5000000105       -0.0000000821        0.0000000157
H             0.0000000117        0.4999999266        0.0000000133
H             0.0000000127       -0.0000000802        0.5000000130


