&control
  calculation = 'scf'
  prefix = 'ganb4s8'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'high'
/
&system
  ! GaNb4S8 lacunar spinel, cubic F-43m (No.216), PRIMITIVE FCC cell (13 atoms).
  ! a_conv=9.95 Ang -> celldm(1)=18.8028 Bohr. Nb4 cluster Nb-Nb=2.859 A; inner Nb-S=2.43 A (breathing-active).
  ! Wyckoff x: Nb(16e)=0.6016 S1(16e,inner)=0.3627 S2(16e,outer)=0.865. Source: JACS 127,8732(2005) family geometry; bond-length-fitted (state/fb-geom-lambda success verify).
  ! nelec=113 (Ga13 + 4*Nb13 + 8*S6). Cluster-Mott t2 manifold -> DFT+U on Nb-4d (U=2.5 eV). nonmag check via nspin diagnostic.
  ibrav = 2
  celldm(1) = 18.8028
  nat = 13
  ntyp = 3
  ecutwfc = 60
  ecutrho = 600
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.01
/
&electrons
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  mixing_mode = 'local-TF'
  electron_maxstep = 400
  diagonalization = 'david'
/
ATOMIC_SPECIES
  Ga 69.723  Ga.pbe-dn-rrkjus_psl.1.0.0.UPF
  Nb 92.906  Nb.pbe-spn-rrkjus_psl.1.0.0.UPF
  S  32.06   S.pbe-n-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Ga 0.000000 0.000000 0.000000
  Nb 0.398400 0.804800 0.398400
  Nb 0.398400 0.398400 0.398400
  Nb 0.398400 0.398400 0.804800
  Nb 0.804800 0.398400 0.398400
  S  0.637300 0.088100 0.637300
  S  0.637300 0.637300 0.637300
  S  0.637300 0.637300 0.088100
  S  0.088100 0.637300 0.637300
  S  0.135000 0.595000 0.135000
  S  0.135000 0.135000 0.135000
  S  0.135000 0.135000 0.595000
  S  0.595000 0.135000 0.135000
K_POINTS automatic
  4 4 4 0 0 0
HUBBARD (ortho-atomic)
  U Nb-4d 2.5
