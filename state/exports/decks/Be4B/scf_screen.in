&CONTROL
  calculation     = 'scf'
  prefix          = 'be4b'
  outdir          = './out'
  pseudo_dir      = './pseudo'
  verbosity       = 'high'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav           = 0
  nat             = 10
  ntyp            = 2
  ecutwfc         = 60
  ecutrho         = 480
  nosym           = .false.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  diagonalization = 'david'
  electron_maxstep = 400
/
