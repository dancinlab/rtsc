&control
  calculation = 'vc-relax'
  prefix = 'li2mgh16'
  outdir = './out'
  pseudo_dir = './pseudo'
  tprnfor = .true.
  tstress = .true.
  forc_conv_thr = 1.0d-4
  etot_conv_thr = 1.0d-5
  nstep = 200
  verbosity = 'low'
/
&system
  ibrav = 0
  nat = 38
  ntyp = 3
  ecutwfc = 60.0
  ecutrho = 480.0
  nosym = .true.
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  conv_thr = 1.0d-10
  mixing_beta = 0.4
  electron_maxstep = 400
/
&ions
  ion_dynamics = 'bfgs'
/
&cell
  cell_dynamics = 'bfgs'
  press = 2500.0
  press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Li 6.941 Li.pbe-s-rrkjus_psl.1.0.0.UPF
  Mg 24.305 Mg.pbe-spnl-rrkjus_psl.1.0.0.UPF
  H 1.008 H.pbe-rrkjus_psl.1.0.0.UPF
