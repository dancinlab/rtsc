&CONTROL
  calculation     = 'scf'
  prefix          = 'luh10'
  outdir          = './out'
  pseudo_dir      = './pseudo'
  verbosity       = 'high'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav = 0
  nat             = 11               ! 1 Lu + 10 H
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.           ! keep symmetry off through scf->ph for consistency
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.02
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
ATOMIC_SPECIES
