&CONTROL
  calculation = "scf"
  prefix      = "rbos2o6_soc"
  outdir      = "./out_soc"
  pseudo_dir  = "./pseudo_soc"
  verbosity   = "high"
  tprnfor     = .true.
  tstress     = .false.
/
&SYSTEM
  ibrav        = 2
  celldm(1)    = 19.1845
  nat          = 9
  ntyp         = 3
  ecutwfc      = 70.0
  ecutrho      = 560.0
  occupations  = "smearing"
  smearing     = "mp"
  degauss      = 0.025
  noncolin     = .true.
  lspinorb     = .true.
  starting_magnetization(2) = 0.3
/
&ELECTRONS
  conv_thr        = 1.0d-6
  mixing_beta     = 0.2
  mixing_mode     = "local-TF"
  mixing_ndim     = 12
  electron_maxstep = 250
/
ATOMIC_SPECIES
  Rb   85.468  Rb.rel-pbe-spn-rrkjus_psl.1.0.0.UPF
  Os  190.230  Os.rel-pbe-spn-rrkjus_psl.1.0.0.UPF
  O    15.999  O.rel-pbe-n-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Rb   0.625000  0.375000  0.375000
  Os   0.000000  0.000000  0.000000
  Os   0.500000  0.500000  0.500000
  O    0.685000  0.935000  0.315000
  O    0.065000  0.315000  0.315000
  O    0.685000  0.315000  0.935000
  O    0.315000  0.065000  0.685000
  O    0.935000  0.685000  0.685000
  O    0.315000  0.685000  0.065000
K_POINTS automatic
  6 6 6 0 0 0
