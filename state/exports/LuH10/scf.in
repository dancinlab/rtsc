&CONTROL
  calculation     = 'scf'
  prefix          = 'luh10'
  outdir = './out'
  pseudo_dir = './pseudo'
  verbosity       = 'high'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav           = 2                ! FCC primitive, Fm-3m (SG 225)
  celldm(1)       = 9.30           ! REPLACE with relaxed celldm(1) from vc-relax.out
  nat             = 11               ! 1 Lu + 10 H
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.           ! keep symmetry off through scf->ph for consistency
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.02
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Lu  174.967   Lu.pbe-spdn-rrkjus_psl.1.0.0.UPF
  H   1.008   H.pbe-rrkjus_psl.1.0.0.UPF
! REPLACE positions below with relaxed ATOMIC_POSITIONS from vc-relax.out
ATOMIC_POSITIONS crystal
  Lu  0.0000000   0.0000000   0.0000000
  H   0.2500000   0.2500000   0.2500000
  H   0.7500000   0.7500000   0.7500000
  H   0.3750000   0.3750000   0.3750000
  H  -0.3750000  -0.3750000  -0.3750000
  H   0.3750000   0.3750000  -0.3750000
  H  -0.3750000  -0.3750000   0.3750000
  H   0.3750000  -0.3750000   0.3750000
  H  -0.3750000   0.3750000  -0.3750000
  H  -0.3750000   0.3750000   0.3750000
  H   0.3750000  -0.3750000  -0.3750000

K_POINTS automatic
  12 12 12  0 0 0
