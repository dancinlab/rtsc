&CONTROL
  calculation     = 'scf'
  prefix          = 'yh9'
  outdir = './out'
  verbosity       = 'high'
  pseudo_dir = './pseudo'
  tstress         = .true.
  tprnfor         = .true.
/
&SYSTEM
  ibrav           = 4                ! hexagonal, P6_3/mmc (SG 194) — YH9 H29 clathrate (Kong 2021, 243K@201GPa)
  celldm(1)       = 6.7700           ! REPLACE with relaxed celldm(1) from vc-relax.out
  celldm(3)       = 1.4936           ! c/a ~ 5.543/3.711 (CeH9 ratio @100GPa; vc-relax refines)
  nat             = 20               ! 2 Y (2d) + 2 H (2b) + 4 H (4f) + 12 H (12k) = YH9 (Z=2)
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.
  occupations     = 'smearing'
  smearing        = 'mp'
  degauss         = 0.01
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Y   88.9059  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  H    1.008   H.pbe-rrkjus_psl.1.0.0.UPF

