&CONTROL
  ! Im-3m (SG 229) BCC H3S — isostructural to Im-3m H3S.
  ! X @ 2a (0,0,0), H @ 6b (1/2,0,0) — H midway between body-centered X.
  ! START celldm(1)=5.60 Bohr (~2.96 A). vc-relax FINDS true a @ 200 GPa (Drozdov Nature 2015 Tc=203K; Im-3m SG229 VALIDATION ANCHOR).
  calculation     = 'vc-relax'
  prefix          = 'h3s'
  outdir = './out'
  pseudo_dir = './pseudo'
  forc_conv_thr   = 1.0d-4
  etot_conv_thr   = 1.0d-6
  tstress         = .true.
  tprnfor         = .true.
  nstep           = 200
/
&SYSTEM
  ibrav           = 3                ! BCC primitive, Im-3m (SG 229) — H3S prototype
  celldm(1)       = 5.60           ! a_conv ~ 2.96 A
  nat             = 4                ! 1 S + 3 H (BCC primitive, 1 f.u.)
  ntyp            = 2
  ecutwfc         = 80
  ecutrho         = 800
  nosym           = .true.           ! guard — avoids checkallsym crash
  occupations     = 'smearing'
  smearing        = 'mp'             ! Methfessel-Paxton — metallic hydride (d15)
  degauss         = 0.02             ! d15 small-gap SCF aid
/
&ELECTRONS
  conv_thr        = 1.0d-10
  mixing_beta     = 0.3
  mixing_mode     = 'plain'
  diagonalization = 'david'
  electron_maxstep = 400             ! d15 maxiter 400
/
&IONS
  ion_dynamics    = 'bfgs'
/
&CELL
  cell_dynamics   = 'bfgs'
  press           = 2000.0          ! target 200 GPa (Drozdov Nature 2015 Tc=203K; Im-3m SG229 VALIDATION ANCHOR)
  press_conv_thr  = 0.5
  cell_dofree     = 'all'
/
ATOMIC_SPECIES
  S  32.06   S.pbe-n-rrkjus_psl.1.0.0.UPF
  H   1.008   H.pbe-rrkjus_psl.1.0.0.UPF

! Im-3m H3S: S @ 2a (0,0,0), H @ 6b (1/2,0,0)/(0,1/2,0)/(0,0,1/2).
! BCC-primitive fractional coords (3 H at the cubic face-midpoints).
ATOMIC_POSITIONS crystal
  S  0.0000000   0.0000000   0.0000000
  H   0.5000000   0.0000000   0.0000000
  H   0.0000000   0.5000000   0.0000000
  H   0.0000000   0.0000000   0.5000000

K_POINTS automatic
  16 16 16  0 0 0
