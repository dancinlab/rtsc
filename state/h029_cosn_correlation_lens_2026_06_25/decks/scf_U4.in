&control
  calculation='scf'
  prefix='cosnU4'
  outdir='./outU4'
  pseudo_dir='./pseudo'
/
&system
ibrav=4
  celldm(1)=9.9760
  celldm(3)=0.80680
  nat=6
  ntyp=2
  ecutwfc=65
  ecutrho=520
  occupations='smearing'
  smearing='mp'
  degauss=0.03
  nspin=2
  starting_magnetization(1)=0.3
  starting_magnetization(2)=0.0
/
&electrons
  conv_thr=1.0d-4
  mixing_beta=0.3
  electron_maxstep=40
/
ATOMIC_SPECIES
  Co 58.933 Co.pbe-spn-rrkjus_psl.0.3.1.UPF
  Sn 118.71 Sn.pbe-dn-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Co 0.500000 0.000000 0.000000
  Co 0.000000 0.500000 0.000000
  Co 0.500000 0.500000 0.000000
  Sn 0.000000 0.000000 0.000000
  Sn 0.333333 0.666667 0.500000
  Sn 0.666667 0.333333 0.500000
K_POINTS automatic
  4 4 4 0 0 0
HUBBARD (ortho-atomic)
  U Co-3d 4.0
