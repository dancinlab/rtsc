&CONTROL
  calculation = 'scf'
  prefix = 'cosn'
  outdir = './out'
  pseudo_dir = '../pseudo'
  verbosity = 'low'
/
&SYSTEM
  ibrav = 4
  a = 5.2693
  c = 4.2431
  nat = 6
  ntyp = 2
  ecutwfc = 55.0
  ecutrho = 220.0
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.05
  nspin = 1
/
&ELECTRONS
  conv_thr = 1.0d-6
  mixing_beta = 0.3
  mixing_mode = 'plain'
  mixing_ndim = 8
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Co  58.933  Co_ONCV_PBE_sr.upf
  Sn  118.710 Sn_ONCV_PBE_sr.upf
ATOMIC_POSITIONS {crystal}
  Co  0.5  0.0  0.0
  Co  0.0  0.5  0.0
  Co  0.5  0.5  0.0
  Sn  0.0  0.0  0.5
  Sn  0.3333333333  0.6666666667  0.0
  Sn  0.6666666667  0.3333333333  0.0
K_POINTS {automatic}
  8 8 8 0 0 0
